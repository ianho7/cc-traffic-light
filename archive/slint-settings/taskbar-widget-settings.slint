export global Theme {
    in-out property <bool> dark_mode;

    out property <brush> color_bg_app: dark_mode ? #111111 : #f4f1ea;
    out property <brush> color_bg_panel: dark_mode ? #171717 : #fbfaf6;
    out property <brush> color_bg_panel_soft: dark_mode ? #1d1d1d : #f7f4ed;
    out property <brush> color_text_main: dark_mode ? #f4f4f4 : #111111;
    out property <brush> color_text_sub: dark_mode ? #d1d1d1 : #606060;
    out property <brush> color_text_muted: dark_mode ? #989898 : #8b8b8b;
    out property <brush> color_border: dark_mode ? #2a2a2a : #d8d2c6;
    out property <brush> color_border_soft: dark_mode ? #343434 : #e6e0d5;
    out property <brush> color_border_strong: dark_mode ? #f4f4f4 : #111111;
    out property <brush> color_status_ok: #3ba55d;
    out property <brush> color_status_warn: #d6a439;
    out property <brush> color_status_error: #d64a3a;
    out property <brush> color_status_idle: #9a9a9a;
    out property <length> radius_xs: 4px;
    out property <length> radius_sm: 8px;
    out property <length> radius_md: 12px;
    out property <length> radius_lg: 16px;
    out property <length> radius_pill: 999px;
    out property <length> space_1: 4px;
    out property <length> space_2: 8px;
    out property <length> space_3: 12px;
    out property <length> space_4: 16px;
    out property <length> space_5: 20px;
    out property <length> space_6: 24px;
    out property <length> space_8: 32px;
    out property <length> space_10: 40px;
    out property <length> font_display: 48px;
    out property <length> font_page_title: 30px;
    out property <length> font_section_title: 14px;
    out property <length> font_body: 16px;
    out property <length> font_caption: 12px;
    out property <length> font_micro: 11px;
}

component StatusDot inherits Rectangle {
    in property <brush> dot_color;
    in property <bool> hollow;

    width: 10px;
    height: 10px;
    border-radius: Theme.radius_pill;
    border-width: 1px;
    border-color: dot_color;
    background: hollow ? transparent : dot_color;
}

component SideNavItem inherits Rectangle {
    in property <string> index_text;
    in property <string> title_text;
    in property <string> label_text;
    in property <bool> active;

    border-radius: Theme.radius_md;
    border-width: 1.5px;
    border-color: active ? Theme.color_border_strong : Theme.color_border_strong;
    background: active ? Theme.color_border_strong : Theme.color_bg_panel_soft;

    HorizontalLayout {
        padding-left: 22px;
        padding-right: 22px;
        spacing: 8px;
        alignment: center;

        Text {
            text: index_text;
            color: active ? Theme.color_bg_panel : Theme.color_text_muted;
            font-family: "Cascadia Mono";
            font-size: Theme.font_micro;
            font-weight: 700;
            letter-spacing: 1.0px;
            vertical-alignment: center;
        }

        VerticalLayout {
            spacing: 2px;

            Text {
                text: title_text;
                color: active ? Theme.color_bg_panel : Theme.color_text_main;
                font-family: "Microsoft YaHei UI";
                font-size: 14px;
                font-weight: 800;
            }

            Text {
                text: label_text;
                color: active ? #d9d9d9 : Theme.color_text_muted;
                font-family: "Cascadia Mono";
                font-size: 10px;
                font-weight: 700;
                letter-spacing: 1.2px;
            }
        }
    }
}

component Panel inherits Rectangle {
    horizontal-stretch: 1;
    vertical-stretch: 1;
    border-radius: Theme.radius_lg;
    background: Theme.color_bg_panel;
    border-width: 1px;
    border-color: Theme.color_border;
}

component AppShell inherits Rectangle {
    background: Theme.color_bg_app;
}

component SectionBlock inherits Rectangle {
    border-radius: Theme.radius_md;
    border-width: 1px;
    border-color: Theme.color_border;
    background: Theme.color_bg_panel_soft;
}

component DemoCard inherits Rectangle {
    in property <string> eyebrow_text;
    in property <string> value_text;
    in property <string> detail_text;
    in property <brush> value_brush;
    in property <length> value_size;
    in property <length> min_card_height;

    min-height: min_card_height;
    border-radius: Theme.radius_lg;
    border-width: 1px;
    border-color: Theme.color_border;
    background: Theme.color_bg_panel_soft;

    VerticalLayout {
        padding: 29px;
        spacing: 16px;

        Text {
            text: eyebrow_text;
            color: Theme.color_text_sub;
            font-family: "Cascadia Mono";
            font-size: 13px;
            font-weight: 900;
            letter-spacing: 1.4px;
        }

        Text {
            text: value_text;
            color: value_brush;
            font-family: "Microsoft YaHei UI";
            font-size: value_size;
            font-weight: 800;
            letter-spacing: -2px;
        }

        Rectangle { vertical-stretch: 1; background: transparent; }

        Text {
            text: detail_text;
            color: Theme.color_text_sub;
            font-family: "Microsoft YaHei UI";
            font-size: 16px;
            wrap: word-wrap;
        }
    }
}

component SectionHeader inherits Rectangle {
    in property <string> title_text;
    in property <string> note_text;

    min-height: 46px;
    border-width: 0px;
    background: transparent;

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 12px;
        alignment: center;

        Text {
            text: title_text;
            color: Theme.color_text_sub;
            font-family: "Cascadia Mono";
            font-size: Theme.font_caption;
            font-weight: 700;
            letter-spacing: 1.2px;
            horizontal-stretch: 1;
        }

        Text {
            text: note_text;
            color: Theme.color_text_muted;
            font-family: "Microsoft YaHei UI";
            font-size: Theme.font_caption;
            horizontal-alignment: right;
        }
    }
}

component ValuePill inherits Rectangle {
    in property <string> value_text;

    min-width: 96px;
    min-height: 30px;
    border-radius: Theme.radius_pill;
    border-width: 1px;
    border-color: Theme.color_border;
    background: Theme.color_bg_panel;

    Text {
        width: parent.width;
        height: parent.height;
        text: value_text;
        color: Theme.color_text_main;
        font-family: "Cascadia Mono";
        font-size: Theme.font_micro;
        font-weight: 700;
        letter-spacing: 0.8px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component InfoRow inherits Rectangle {
    in property <string> title_text;
    in property <string> key_text;
    in property <string> value_text;
    in property <bool> compact_value;

    min-height: 66px;
    border-width: 1px;
    border-color: Theme.color_border;
    background: transparent;

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 16px;
        alignment: center;

        VerticalLayout {
            spacing: 3px;
            horizontal-stretch: 1;

            Text {
                text: title_text;
                color: Theme.color_text_main;
                font-family: "Microsoft YaHei UI";
                font-size: Theme.font_body;
                font-weight: 600;
            }

            Text {
                text: key_text;
                color: Theme.color_text_muted;
                font-family: "Cascadia Mono";
                font-size: Theme.font_micro;
                font-weight: 700;
                letter-spacing: 1.0px;
            }
        }

        if compact_value : ValuePill {
            value_text: root.value_text;
        }

        if !compact_value : Text {
            text: value_text;
            color: Theme.color_text_sub;
            font-family: "Cascadia Mono";
            font-size: Theme.font_caption;
            font-weight: 700;
            letter-spacing: 0.4px;
            wrap: word-wrap;
            horizontal-alignment: right;
            vertical-alignment: center;
            width: 250px;
        }
    }
}

component SettingToggleRow inherits Rectangle {
    in property <string> title_text;
    in property <string> key_text;
    in property <bool> enabled;

    min-height: 66px;
    border-width: 1px;
    border-color: Theme.color_border;
    background: transparent;

    HorizontalLayout {
        padding-left: 18px;
        padding-right: 18px;
        spacing: 16px;
        alignment: center;

        VerticalLayout {
            spacing: 3px;
            horizontal-stretch: 1;

            Text {
                text: title_text;
                color: Theme.color_text_main;
                font-family: "Microsoft YaHei UI";
                font-size: Theme.font_body;
                font-weight: 600;
            }

            Text {
                text: key_text;
                color: Theme.color_text_muted;
                font-family: "Cascadia Mono";
                font-size: Theme.font_micro;
                font-weight: 700;
                letter-spacing: 1.0px;
            }
        }

        Rectangle {
            min-width: 106px;
            min-height: 34px;
            border-radius: Theme.radius_pill;
            border-width: 1px;
            border-color: Theme.color_border_strong;
            background: enabled ? Theme.color_border_strong : Theme.color_bg_panel;

            HorizontalLayout {
                padding-left: 12px;
                padding-right: 12px;
                spacing: 8px;
                alignment: center;

                Text {
                    text: enabled ? "ON" : "OFF";
                    color: enabled ? Theme.color_bg_panel : Theme.color_text_main;
                    font-family: "Cascadia Mono";
                    font-size: Theme.font_micro;
                    font-weight: 700;
                    letter-spacing: 1.0px;
                }

                StatusDot {
                    dot_color: enabled ? Theme.color_status_ok : Theme.color_status_idle;
                    hollow: !enabled;
                }
            }
        }
    }
}

component ActionButton inherits Rectangle {
    in property <string> text_value;

    min-width: 164px;
    min-height: 44px;
    border-radius: Theme.radius_pill;
    border-width: 1px;
    border-color: Theme.color_border_strong;
    background: Theme.color_bg_panel;

    Text {
        width: parent.width;
        height: parent.height;
        text: text_value;
        color: Theme.color_text_main;
        font-family: "Cascadia Mono";
        font-size: Theme.font_micro;
        font-weight: 700;
        letter-spacing: 1.0px;
        horizontal-alignment: center;
        vertical-alignment: center;
    }
}

component DeviceSpecRow inherits Rectangle {
    in property <string> key_text;
    in property <string> value_text;

    min-height: 69px;
    border-width: 0px;
    background: transparent;

    Rectangle {
        x: 0;
        y: parent.height - 1px;
        width: parent.width;
        height: 1px;
        background: Theme.color_border_soft;
    }

    HorizontalLayout {
        padding-left: 20px;
        padding-right: 20px;
        spacing: 16px;
        alignment: center;

        Text {
            min-width: 180px;
            text: key_text;
            color: Theme.color_text_sub;
            font-family: "Cascadia Mono";
            font-size: Theme.font_caption;
            font-weight: 900;
            letter-spacing: 1.0px;
        }

        Text {
            text: value_text;
            color: Theme.color_text_main;
            font-family: "Microsoft YaHei UI";
            font-size: 17px;
            wrap: word-wrap;
            horizontal-stretch: 1;
        }
    }
}

export component SettingsWindow inherits Window {
    callback toggle_autostart();
    callback toggle_start_minimized();
    callback toggle_close_to_tray();
    callback cycle_language();
    callback request_refresh();
    callback select_page(int);
    callback toggle_monitoring_codex();
    callback toggle_monitoring_claude();
    callback cycle_indicator_style();
    callback cycle_widget_size();
    callback cycle_ui_theme();
    callback toggle_show_labels();
    callback toggle_reduced_motion();

    in property <string> window_title;
    in property <string> badge_text;
    in property <string> page_title;
    in property <string> page_subtitle;
    in property <string> nav_overview_text;
    in property <string> nav_general_text;
    in property <string> nav_monitoring_text;
    in property <string> nav_appearance_text;
    in property <string> nav_diagnostics_text;
    in property <string> nav_about_text;
    in property <int> selected_page;
    in property <string> hero_label;
    in property <string> hero_value;
    in property <string> hero_detail;
    in property <string> hero_meta;
    in property <string> widget_label;
    in property <string> widget_value;
    in property <string> widget_detail;
    in property <string> codex_label;
    in property <string> codex_value;
    in property <string> codex_detail;
    in property <string> claude_label;
    in property <string> claude_value;
    in property <string> claude_detail;
    in property <brush> hero_status_color;
    in property <brush> widget_status_color;
    in property <brush> codex_status_color;
    in property <brush> claude_status_color;
    in property <bool> hero_status_hollow;
    in property <bool> widget_status_hollow;
    in property <bool> codex_status_hollow;
    in property <bool> claude_status_hollow;
    in property <string> general_title;
    in property <string> autostart_label;
    in property <string> autostart_value;
    in property <string> start_minimized_label;
    in property <string> start_minimized_value;
    in property <string> close_to_tray_label;
    in property <string> close_to_tray_value;
    in property <string> language_label;
    in property <string> language_value;
    in property <string> monitoring_title;
    in property <string> monitoring_hint;
    in property <string> monitoring_codex_label;
    in property <string> monitoring_codex_value;
    in property <string> monitoring_claude_label;
    in property <string> monitoring_claude_value;
    in property <string> appearance_title;
    in property <string> appearance_hint;
    in property <bool> dark_mode;
    in property <string> ui_theme_label;
    in property <string> ui_theme_value;
    in property <string> indicator_style_label;
    in property <string> indicator_style_value;
    in property <string> widget_size_label;
    in property <string> widget_size_value;
    in property <string> show_labels_label;
    in property <string> show_labels_value;
    in property <string> reduced_motion_label;
    in property <string> reduced_motion_value;
    in property <string> diagnostics_title;
    in property <string> diagnostics_hint;
    in property <string> diagnostics_button_text;
    in property <string> diagnostics_primary;
    in property <string> diagnostics_secondary;
    in property <string> diagnostics_codex;
    in property <string> diagnostics_claude;
    in property <string> about_title;
    in property <string> about_description;
    in property <string> about_product_value;
    in property <string> about_version_label;
    in property <string> about_version_value;
    in property <string> about_runtime_label;
    in property <string> about_runtime_value;
    in property <string> about_config_label;
    in property <string> about_config_value;
    in property <string> about_language_mode_label;
    in property <string> about_language_mode_value;

    title: window_title;
    width: 1120px;
    height: 760px;
    background: Theme.color_bg_app;

    AppShell {
        width: parent.width;
        height: parent.height;

        HorizontalLayout {
            width: parent.width;
            height: parent.height;
            padding: Theme.space_8;
            spacing: Theme.space_8;

            Panel {
                min-width: 272px;
                max-width: 272px;

                VerticalLayout {
                    padding: 28px;
                    spacing: 14px;

                    Text {
                        text: badge_text;
                        color: Theme.color_text_sub;
                        font-family: "Microsoft YaHei UI";
                        font-size: 13px;
                        font-weight: 700;
                    }

                    Text {
                        text: page_title;
                        color: Theme.color_text_main;
                        font-family: "Microsoft YaHei UI";
                        font-size: 34px;
                        font-weight: 500;
                        letter-spacing: -2px;
                    }

                    Text {
                        text: page_subtitle;
                        color: Theme.color_text_sub;
                        font-family: "Microsoft YaHei UI";
                        font-size: 18px;
                        wrap: word-wrap;
                    }

                    Rectangle { min-height: 44px; background: transparent; }

                    Rectangle {
                        min-height: 76px;
                        background: transparent;
                        SideNavItem { width: parent.width; height: parent.height; index_text: "01"; title_text: nav_overview_text; label_text: "OVERVIEW"; active: selected_page == 0; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.select_page(0); } }
                    }
                    Rectangle {
                        min-height: 76px;
                        background: transparent;
                        SideNavItem { width: parent.width; height: parent.height; index_text: "02"; title_text: nav_general_text; label_text: "GENERAL"; active: selected_page == 1; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.select_page(1); } }
                    }
                    Rectangle {
                        min-height: 76px;
                        background: transparent;
                        SideNavItem { width: parent.width; height: parent.height; index_text: "03"; title_text: nav_monitoring_text; label_text: "SOURCES"; active: selected_page == 2; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.select_page(2); } }
                    }
                    Rectangle {
                        min-height: 76px;
                        background: transparent;
                        SideNavItem { width: parent.width; height: parent.height; index_text: "04"; title_text: nav_appearance_text; label_text: "APPEARANCE"; active: selected_page == 3; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.select_page(3); } }
                    }
                    Rectangle {
                        min-height: 76px;
                        background: transparent;
                        SideNavItem { width: parent.width; height: parent.height; index_text: "05"; title_text: nav_diagnostics_text; label_text: "DIAGNOSTICS"; active: selected_page == 4; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.select_page(4); } }
                    }
                    Rectangle {
                        min-height: 76px;
                        background: transparent;
                        SideNavItem { width: parent.width; height: parent.height; index_text: "06"; title_text: nav_about_text; label_text: "ABOUT"; active: selected_page == 5; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.select_page(5); } }
                    }

                    Rectangle { vertical-stretch: 1; background: transparent; }
                }
            }

            Panel {
                horizontal-stretch: 1;
                vertical-stretch: 1;

                if selected_page == 0 : VerticalLayout {
                    padding: 31px;
                    spacing: 20px;

                    HorizontalLayout {
                        spacing: 20px;

                        DemoCard {
                            horizontal-stretch: 1;
                            eyebrow_text: hero_label;
                            value_text: hero_value;
                            detail_text: hero_detail;
                            value_brush: Theme.color_text_main;
                            value_size: 54px;
                            min_card_height: 185px;
                        }

                        DemoCard {
                            horizontal-stretch: 1;
                            eyebrow_text: widget_label;
                            value_text: widget_value;
                            detail_text: widget_detail;
                            value_brush: Theme.color_text_main;
                            value_size: 54px;
                            min_card_height: 185px;
                        }
                    }

                    HorizontalLayout {
                        spacing: 20px;

                        DemoCard {
                            horizontal-stretch: 1;
                            eyebrow_text: codex_label;
                            value_text: codex_value;
                            detail_text: codex_detail;
                            value_brush: codex_status_color;
                            value_size: 45px;
                            min_card_height: 342px;
                        }

                        DemoCard {
                            horizontal-stretch: 1;
                            eyebrow_text: claude_label;
                            value_text: claude_value;
                            detail_text: claude_detail;
                            value_brush: claude_status_color;
                            value_size: 45px;
                            min_card_height: 342px;
                        }
                    }

                    Rectangle { vertical-stretch: 1; background: transparent; }
                }

            if selected_page == 1 : VerticalLayout {
                padding: 28px;
                spacing: 18px;

                Text {
                    text: general_title;
                    color: Theme.color_text_main;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_page_title;
                    font-weight: 500;
                }

                SectionBlock {
                    horizontal-stretch: 1;

                    VerticalLayout {
                        spacing: 0px;
                        SectionHeader { title_text: "SYSTEM BEHAVIOR"; note_text: "NO NEW SETTINGS"; }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: autostart_label; key_text: "START_ON_LOGIN"; enabled: autostart_value == "ON" || autostart_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_autostart(); } } }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: start_minimized_label; key_text: "MINIMIZE_ON_START"; enabled: start_minimized_value == "ON" || start_minimized_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_start_minimized(); } } }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: close_to_tray_label; key_text: "CLOSE_TO_TRAY"; enabled: close_to_tray_value == "ON" || close_to_tray_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_close_to_tray(); } } }
                        Rectangle { min-height: 66px; background: transparent; InfoRow { width: parent.width; height: parent.height; title_text: language_label; key_text: "LANGUAGE_MODE"; value_text: language_value; compact_value: true; } TouchArea { width: parent.width; height: parent.height; clicked => { root.cycle_language(); } } }
                    }
                }

                Rectangle { vertical-stretch: 1; background: transparent; }
            }

            if selected_page == 2 : VerticalLayout {
                padding: 28px;
                spacing: 18px;

                Text {
                    text: monitoring_title;
                    color: Theme.color_text_main;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_page_title;
                    font-weight: 500;
                }

                Text {
                    text: monitoring_hint;
                    color: Theme.color_text_sub;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_body;
                    wrap: word-wrap;
                }

                SectionBlock {
                    horizontal-stretch: 1;

                    VerticalLayout {
                        spacing: 0px;
                        SectionHeader { title_text: "SOURCE MATRIX"; note_text: "LOCAL INPUTS ONLY"; }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: monitoring_codex_label; key_text: "CODEX_SOURCE"; enabled: monitoring_codex_value == "ON" || monitoring_codex_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_monitoring_codex(); } } }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: monitoring_claude_label; key_text: "CLAUDE_CODE_SOURCE"; enabled: monitoring_claude_value == "ON" || monitoring_claude_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_monitoring_claude(); } } }
                    }
                }

                Rectangle { vertical-stretch: 1; background: transparent; }
            }

            if selected_page == 3 : VerticalLayout {
                padding: 28px;
                spacing: 18px;

                Text {
                    text: appearance_title;
                    color: Theme.color_text_main;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_page_title;
                    font-weight: 500;
                }

                Text {
                    text: appearance_hint;
                    color: Theme.color_text_sub;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_body;
                    wrap: word-wrap;
                }

                SectionBlock {
                    horizontal-stretch: 1;

                    VerticalLayout {
                        spacing: 0px;
                        SectionHeader { title_text: "DISPLAY SURFACE"; note_text: "LOCAL DISPLAY ONLY"; }
                        Rectangle { min-height: 66px; background: transparent; InfoRow { width: parent.width; height: parent.height; title_text: ui_theme_label; key_text: "THEME_MODE"; value_text: ui_theme_value; compact_value: true; } TouchArea { width: parent.width; height: parent.height; clicked => { root.cycle_ui_theme(); } } }
                        Rectangle { min-height: 66px; background: transparent; InfoRow { width: parent.width; height: parent.height; title_text: indicator_style_label; key_text: "INDICATOR_STYLE"; value_text: indicator_style_value; compact_value: true; } TouchArea { width: parent.width; height: parent.height; clicked => { root.cycle_indicator_style(); } } }
                        Rectangle { min-height: 66px; background: transparent; InfoRow { width: parent.width; height: parent.height; title_text: widget_size_label; key_text: "COMPONENT_SIZE"; value_text: widget_size_value; compact_value: true; } TouchArea { width: parent.width; height: parent.height; clicked => { root.cycle_widget_size(); } } }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: show_labels_label; key_text: "SHOW_LABELS"; enabled: show_labels_value == "ON" || show_labels_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_show_labels(); } } }
                        Rectangle { min-height: 66px; background: transparent; SettingToggleRow { width: parent.width; height: parent.height; title_text: reduced_motion_label; key_text: "REDUCE_MOTION"; enabled: reduced_motion_value == "ON" || reduced_motion_value == "开"; } TouchArea { width: parent.width; height: parent.height; clicked => { root.toggle_reduced_motion(); } } }
                    }
                }

                Rectangle { vertical-stretch: 1; background: transparent; }
            }

            if selected_page == 4 : VerticalLayout {
                padding: 28px;
                spacing: 18px;

                Text {
                    text: diagnostics_title;
                    color: Theme.color_text_main;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_page_title;
                    font-weight: 500;
                }

                Text {
                    text: diagnostics_hint;
                    color: Theme.color_text_sub;
                    font-family: "Microsoft YaHei UI";
                    font-size: Theme.font_body;
                    wrap: word-wrap;
                }

                Text {
                    text: "最近刷新: " + diagnostics_primary;
                    color: Theme.color_text_main;
                    font-family: "Microsoft YaHei UI";
                    font-size: 18px;
                }

                Text {
                    text: "最近错误: " + diagnostics_secondary;
                    color: Theme.color_text_sub;
                    font-family: "Microsoft YaHei UI";
                    font-size: 16px;
                }

                Text {
                    text: diagnostics_codex;
                    color: Theme.color_text_sub;
                    font-family: "Cascadia Mono";
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Text {
                    text: diagnostics_claude;
                    color: Theme.color_text_sub;
                    font-family: "Cascadia Mono";
                    font-size: 13px;
                    wrap: word-wrap;
                }

                Rectangle { vertical-stretch: 1; background: transparent; }

                HorizontalLayout {
                    Rectangle { horizontal-stretch: 1; background: transparent; }
                    Rectangle {
                        min-width: 195px;
                        min-height: 56px;
                        background: transparent;
                        ActionButton { width: parent.width; height: parent.height; text_value: diagnostics_button_text; }
                        TouchArea { width: parent.width; height: parent.height; clicked => { root.request_refresh(); } }
                    }
                }

                Rectangle { vertical-stretch: 1; background: transparent; }
            }

                if selected_page == 5 : VerticalLayout {
                    padding: 28px;
                    spacing: 18px;

                    Text {
                        text: about_title;
                        color: Theme.color_text_main;
                        font-family: "Microsoft YaHei UI";
                        font-size: Theme.font_page_title;
                        font-weight: 500;
                    }

                    Text {
                        text: about_description;
                        color: Theme.color_text_sub;
                        font-family: "Microsoft YaHei UI";
                        font-size: Theme.font_body;
                        wrap: word-wrap;
                    }

                    SectionBlock {
                        horizontal-stretch: 1;

                        VerticalLayout {
                            spacing: 0px;
                            SectionHeader { title_text: "DEVICE SPEC"; note_text: "NO EXTRA ACTIONS"; }
                            DeviceSpecRow { width: parent.width; key_text: "PRODUCT"; value_text: about_product_value; }
                            DeviceSpecRow { width: parent.width; key_text: "VERSION"; value_text: about_version_value; }
                            DeviceSpecRow { width: parent.width; key_text: "RUNTIME"; value_text: about_runtime_value; }
                            DeviceSpecRow { width: parent.width; key_text: "CONFIG"; value_text: about_config_value; }
                            DeviceSpecRow { width: parent.width; key_text: "LANGUAGE"; value_text: about_language_mode_value; }
                        }
                    }

                    Rectangle { vertical-stretch: 1; background: transparent; }
                }
            }
        }
    }
}
