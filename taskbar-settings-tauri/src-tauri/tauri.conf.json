{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CC Traffic Light Settings",
  "version": "0.1.0",
  "identifier": "com.cctrafficlight.settings",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:1420",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "CC Traffic Light Settings",
        "width": 800,
        "height": 600,
        "minWidth": 400,
        "minHeight": 300,
        "resizable": true
      }
    ],
    "security": {
      "capabilities": [
        "main-capability"
      ]
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}